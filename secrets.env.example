# ─── Local Android SDK paths ──────────────────────────────────────────────────
JAVA_HOME=C:\Program Files\Java\jdk-21
ANDROID_HOME=C:\Users\Izhe\AppData\Local\Android\Sdk

# ─── Android release signing (required for Play Console AAB upload) ─────────
RELEASE_STORE_FILE=d:\Alerts\android-app\release-keystore.jks
RELEASE_STORE_PASSWORD=INSERT_RELEASE_STORE_PASSWORD
RELEASE_KEY_ALIAS=INSERT_RELEASE_KEY_ALIAS
RELEASE_KEY_PASSWORD=INSERT_RELEASE_KEY_PASSWORD

# ─── VPS SSH access ───────────────────────────────────────────────────────────
VPS_SSH_KEY=d:\Alerts\VPS-54592
VPS_SSH_USER=root@173.242.53.129

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://INSERT_DB_USER:INSERT_DB_PASSWORD@173.242.53.129/alerts_ua
VPS_DB_URL=postgresql://INSERT_DB_USER:INSERT_DB_PASSWORD@127.0.0.1:5432/alerts_ua
NODE_ENV=development

# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://INSERT_PROJECT_ID.supabase.co
SUPABASE_PUBLISHABLE_KEY=INSERT_SUPABASE_PUBLISHABLE_KEY
SUPABASE_SECRET_KEY=INSERT_SUPABASE_SECRET_KEY
SUPABASE_SERVICE_KEY=INSERT_SUPABASE_SERVICE_KEY
SUPABASE_PROJECT_ID=INSERT_PROJECT_ID
SUPABASE_ACCESS_TOKEN=INSERT_SUPABASE_ACCESS_TOKEN

# ─── Redis (local dev: start redis locally or point to VPS via SSH tunnel) ────
REDIS_URL=redis://127.0.0.1:6379/3
REDIS_KEY_PREFIX=alerts-ua:

# ─── Firebase (fill from Firebase console → service account JSON) ─────────────
# Local path to the service account JSON file (used by push worker)
FIREBASE_SERVICE_ACCOUNT_PATH=d:\Alerts\alert-ua-app-firebase-adminsdk-fbsvc-48f98daed8.json
FIREBASE_PROJECT_ID=alert-ua-app
FIREBASE_PRIVATE_KEY=INSERT_FIREBASE_PRIVATE_KEY
FIREBASE_CLIENT_EMAIL=INSERT_FIREBASE_CLIENT_EMAIL

# ─── Telegram (fill from my.telegram.org + session generator script) ──────────
TELEGRAM_API_ID=INSERT_TELEGRAM_API_ID
TELEGRAM_API_HASH=INSERT_TELEGRAM_API_HASH
TELEGRAM_SESSION_STRING=INSERT_TELEGRAM_SESSION_STRING
TELEGRAM_CHANNEL_REFS=@kpszsu

# ─── Gemini (fill from Google AI Studio) ──────────────────────────────────────
GEMINI_API_KEY=INSERT_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash

# ─── Worker tunables (non-secret, edit freely) ────────────────────────────────
TELEGRAM_INGEST_LIMIT=100
TELEGRAM_PARSER_BATCH=20
TELEGRAM_PARSER_MAX_ATTEMPTS=3
GEMINI_TIMEOUT_MS=30000
